{
  "name": "@localcode/cli",
  "version": "4.0.0",
  "description": "Full-featured AI coding agent with 139 specialized agents, multi-agent orchestration, local LLM support, and VS Code integration",
  "bin": {
    "localcode": "dist/bin/localcode.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "install.sh",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/bin/localcode.tsx",
    "start": "node dist/bin/localcode.js"
  },
  "dependencies": {
    "ink": "^4.4.1",
    "ink-text-input": "^5.0.1",
    "react": "^18.2.0",
    "node-fetch": "^3.3.2",
    "chalk": "^5.3.0",
    "glob": "^10.3.10",
    "node-pty": "^1.0.0",
    "axios": "^1.6.0",
    "zod": "^3.22.0",
    "qrcode": "^1.5.3",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/api-logs": "^0.46.0",
    "@opentelemetry/sdk-logs": "^0.46.0",
    "@opentelemetry/sdk-metrics": "^1.19.0",
    "@opentelemetry/sdk-trace-base": "^1.19.0",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "ws": "^8.16.0",
    "@types/ws": "^8.5.10",
    "@types/lodash": "^4.14.202",
    "@types/qrcode": "^1.5.5"
