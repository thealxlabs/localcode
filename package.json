{
  "name": "@localcode/cli",
  "version": "4.0.0",
  "description": "Full-featured AI coding agent with 139 specialized agents, multi-agent orchestration, local LLM support, and VS Code integration",
  "bin": {
    "localcode": "dist/bin/localcode.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "install.sh",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/bin/localcode.tsx",
    "start": "node dist/bin/localcode.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.5",
    "chalk": "^5.3.0",
    "ink": "^4.4.1",
    "ink-text-input": "^5.0.1",
    "qrcode": "^1.5.3",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^18.2.0",
    "@vitest/coverage-v8": "^1.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "ollama",
    "coding",
    "agent",
    "cli",
    "localcode",
    "multi-agent",
    "orchestration",
    "vscode",
    "local-llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thealxlabs/localcode.git"
  },
  "homepage": "https://github.com/thealxlabs/localcode#readme",
  "bugs": {
    "url": "https://github.com/thealxlabs/localcode/issues"
  },
  "author": "TheAlxLabs"
}
